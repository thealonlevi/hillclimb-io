# harness/config — the fixed rules of the game. Sourced by run.sh and the optimizer loop.
# The optimizer reads these but MUST NOT change them (PROJECT.md). Single-box dev defaults.

# --- core budget / topology -------------------------------------------------
CORES=1
SUT_CPUS="2"
LG_CPUS="6-11"
CH_CPUS="0-1,12"

# --- arms -------------------------------------------------------------------
CONTROL_PORT=30
TREAT_PORT=31
BIND_ADDR="0.0.0.0"          # arms listen here
# loadgen target + location:
#   single-box (default): TARGET_HOST=127.0.0.1, LOADGEN_URL="" (loadgen runs locally over loopback)
#   2-box (Track B):      TARGET_HOST=<box-1 address reachable from box 2>,
#                         LOADGEN_URL="http://<box-2 ip>:8088"  (harness drives the remote loadgen API)
TARGET_HOST="${TARGET_HOST:-127.0.0.1}"
LOADGEN_URL="${LOADGEN_URL:-}"

# REPLY_BYTES — 19 bytes, byte-for-byte. The gate validates this exactly.
REPLY_BYTES=$'HTTP/1.1 200 OK\r\n\r\n'

# --- ceiling / gate thresholds ----------------------------------------------
QUEUE_HIGH=40                # sustained accept-queue depth (Recv-Q) => backpressure
DROP_CEILING=0.0001          # < 0.01% connection failures or the step scores 0
SAMPLE_PCT=5                 # % of connections fully payload-validated by the gate

# --- ramp / timing ----------------------------------------------------------
RAMP_CONF="harness/ramp.conf"
LG_THREADS="auto"            # loadgen worker threads; "auto" = the load-generator's core count
# adaptive ramp: auto-scale CONCURRENCY (in-flight connections, closed-loop) until the SUT tops
# out — no hand-tuned rates, and it can't congestion-collapse over a high-latency link.
RAMP_MODE="adaptive"         # adaptive (scale concurrency) | fixed (offered rates from ramp.conf)
CONN_START=32                # first in-flight connection count
CONN_GROWTH=2                # double in-flight each step
CONN_MAX=200000              # safety cap on in-flight connections
PLATEAU_GAIN=0.03            # stop if completed grows <3% despite more concurrency (SUT is the limit)
WARMUP=10                    # seconds per step before measuring
MEASURE=30                   # seconds measured per step
SETTLE=3                     # quiet delay between runs (+ drop_caches)
N=3                          # repetitions per scored config; score = median
SMOKE_TIMEOUT=20             # arm must pass a 100-conn smoke test within this many seconds

# --- optimizer loop knobs ---------------------------------------------------
EPSILON=0.01                 # min fractional improvement to promote a new champion
PATIENCE=30                  # distinct configs without improvement => plateau => STOP
K=20                         # treatment runs between control-drift watchdog checks
CTX_ROTATE_TOKENS=120000     # claude -p session input-token threshold to rotate session
# model tiering: cheap Sonnet for routine exploration, periodic Opus for a deeper attempt.
OPT_MODEL="sonnet"           # default per-iteration model (≈5-10x cheaper than opus)
DEEP_MODEL="opus"            # used every DEEP_EVERY iterations for a harder/deeper attempt
DEEP_EVERY=8                 # 0 = never use DEEP_MODEL (pure Sonnet); 8 = Opus every 8th iter
ITER_TIMEOUT=900             # wall-clock cap per claude -p iteration (seconds)

# --- paths ------------------------------------------------------------------
RESULTS_DIR="results"
HISTORY="results/HISTORY.jsonl"
BEST="results/BEST.json"
CH_DB="acceptbench"

# box-specific overrides (gitignored): LOADGEN_URL, TARGET_HOST, etc.
[ -f harness/config.local ] && . harness/config.local
